# 电商自动化系统环境配置

# 应用配置
APP_NAME=ecommerce-automation
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ecommerce
DB_USER=ecommerce_user
DB_PASSWORD=your_secure_password
DB_CHARSET=utf8mb4

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# RabbitMQ 配置
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# AI 配置
AI_MODEL=kimi-coding/k2p5
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=500

# OpenClaw 配置
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_API_KEY=your-api-key

# 通知配置
# 钉钉
DINGTALK_ENABLED=false
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx
DINGTALK_SECRET=your-secret

# 飞书
FEISHU_ENABLED=false
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# 邮件
EMAIL_ENABLED=false
EMAIL_SMTP_HOST=smtp.company.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=notify@company.com
EMAIL_PASSWORD=your-password
EMAIL_FROM_NAME=电商自动化系统

# 电商平台配置
# 淘宝
TAOBAO_APP_KEY=your-app-key
TAOBAO_APP_SECRET=your-app-secret
TAOBAO_SANDBOX=true

# 京东
JD_APP_KEY=your-app-key
JD_APP_SECRET=your-app-secret

# 拼多多
PDD_CLIENT_ID=your-client-id
PDD_CLIENT_SECRET=your-client-secret

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=/var/log/ecommerce/app.log

# 监控配置
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true
