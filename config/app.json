{
  "project": {
    "name": "ecommerce-automation",
    "version": "1.0.0",
    "description": "RPA + AI + OpenClaw 电商自动化系统"
  },
  "openclaw": {
    "gateway": {
      "port": 18789,
      "bind": "127.0.0.1"
    },
    "agents": {
      "ecommerce": {
        "model": "kimi-coding/k2p5",
        "skills": [
          "customer-service",
          "order-automation",
          "price-monitor",
          "inventory-manager"
        ]
      }
    }
  },
  "database": {
    "host": "localhost",
    "port": 3306,
    "name": "ecommerce",
    "user": "ecommerce_user",
    "password": "${DB_PASSWORD}"
  },
  "redis": {
    "host": "localhost",
    "port": 6379,
    "db": 0
  },
  "ai": {
    "model": "kimi-coding/k2p5",
    "temperature": 0.7,
    "max_tokens": 500
  },
  "cron": {
    "enabled": true,
    "jobs": [
      {
        "name": "process-orders",
        "schedule": "*/10 * * * *",
        "skill": "order-automation",
        "action": "process_pending_orders"
      },
      {
        "name": "check-messages",
        "schedule": "*/5 * * * *",
        "skill": "customer-service",
        "action": "check_pending_messages"
      }
    ]
  }
}
